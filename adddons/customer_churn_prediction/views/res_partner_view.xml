<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Churn Risk to Partner Form View -->
    <record id="view_partner_form_inherit_churn" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.churn</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(crm.crm_lead_action_pipeline)d"
                        context="{'search_default_partner_id': active_id, 'default_partner_id': active_id}"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-life-ring"
                        attrs="{'invisible': [('is_at_risk', '=', False)]}"
                        groups="sales_team.group_sale_salesman">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text text-danger">Retention<br/>Required</span>
                    </div>
                </button>
            </xpath>
            <page name="sales_purchases" position="inside">
                <field name="customer_rank" invisible="1"/>
                <group name="churn" string="Churn Analysis" attrs="{'invisible': [('customer_rank', '=', 0)]}">
                    <field name="churn_risk" readonly="1" widget="percentage"/>
                    <field name="churn_risk_date" readonly="1"/>
                    <field name="is_at_risk" invisible="1"/>
                </group>
            </page>
        </field>
    </record>

    <!-- Add Churn Risk to Partner Kanban View -->
    <record id="res_partner_kanban_view_inherit_churn" model="ir.ui.view">
        <field name="name">res.partner.kanban.inherit.churn</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.res_partner_kanban_view"/>
        <field name="arch" type="xml">
<!--            <field name="mobile" position="after">-->
<!--                <field name="is_at_risk" />-->
<!--            </field>-->
            <xpath expr="//kanban/templates" position="before">
                <field name="is_at_risk" />
            </xpath>
            <xpath expr="//div[hasclass('oe_kanban_details')]" position="inside">
                <div t-if="record.is_at_risk.raw_value" class="mt8">
                    <span class="badge badge-danger">
                        <i class="fa fa-exclamation-triangle"/> Churn Risk: <field name="churn_risk" widget="percentage"/>
                    </span>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Add Churn Risk to Partner Tree View -->
    <record id="view_partner_tree_inherit_churn" model="ir.ui.view">
        <field name="name">res.partner.tree.inherit.churn</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="churn_risk" widget="percentage" optional="show"/>
                <field name="is_at_risk" widget="boolean_toggle" optional="show"/>
            </field>
        </field>
    </record>

