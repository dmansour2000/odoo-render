<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Scheduled Action for Churn Risk Calculation -->
    <record id="ir_cron_churn_risk_calculation" model="ir.cron">
        <field name="name">CRM: Calculate Customer Churn Risk</field>
        <field name="model_id" ref="model_res_partner"/>
        <field name="state">code</field>
        <field name="code">model._cron_calculate_churn_risk()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
    </record>
</odoo>